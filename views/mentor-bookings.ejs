<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Bookings - Mentorise</title>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: {
                50: "#f0f4ff",
                500: "#3A5BA0",
                600: "#2F3C7E",
                700: "#1e2a4a",
              },
              secondary: {
                50: "#fffbf0",
                500: "#FFD447",
                600: "#e6bf40",
              },
              neutral: {
                50: "#F5F7FA",
                100: "#e5e7eb",
                200: "#d1d5db",
                600: "#555555",
                800: "#222222",
              },
            },
            fontFamily: {
              heading: ["Poppins", "Inter", "sans-serif"],
              body: ["Roboto", "Open Sans", "sans-serif"],
            },
          },
        },
      };
    </script>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  
  <body class="bg-neutral-50 font-body">
    <!-- Navigation Bar -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <a href="/mentor-home/<%= mentorId %>">
              <h1 class="text-2xl font-bold text-primary-500 font-heading">Mentorise</h1>
            </a>
          </div>

          <div class="hidden md:block">
            <div class="ml-10 flex items-baseline space-x-4">
              <a href="/mentor-home/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">Home</a>
              <a href="/mentor-profile/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">Profile</a>
              <a href="/view-requests/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">Requests</a>
              <a href="/mentor-bookings/<%= mentorId %>" class="text-primary-500 px-3 py-2 rounded-md text-sm font-medium">My Bookings</a>
            </div>
          </div>

          <div class="hidden md:block">
            <button onclick="logout()" class="text-neutral-800 hover:text-red-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Logout
            </button>
          </div>

          <div class="md:hidden">
            <button id="mobile-menu-button" class="text-neutral-800 hover:text-primary-500 p-2">
              <i class="fas fa-bars text-xl"></i>
            </button>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
        <div class="px-2 pt-2 pb-3 space-y-1">
          <a href="/mentor-home/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 block px-3 py-2 rounded-md text-base font-medium">Home</a>
          <a href="/mentor-profile/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 block px-3 py-2 rounded-md text-base font-medium">Profile</a>
          <a href="/view-requests/<%= mentorId %>" class="text-neutral-800 hover:text-primary-500 block px-3 py-2 rounded-md text-base font-medium">Requests</a>
          <a href="/mentor-bookings/<%= mentorId %>" class="text-primary-500 block px-3 py-2 rounded-md text-base font-medium">My Bookings</a>
          <button onclick="logout()" class="text-neutral-800 hover:text-red-500 block px-3 py-2 rounded-md text-base font-medium w-full text-left">Logout</button>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Page Header -->
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-neutral-800 mb-4 font-heading">My Bookings</h1>
        <p class="text-xl text-neutral-600 max-w-3xl mx-auto">Manage your confirmed sessions and group workshops.</p>
      </div>

      <!-- Tabs -->
      <div class="flex gap-2 mb-8 border-b border-neutral-200">
        <button id="tab-1on1" onclick="switchTab('1on1')"
          class="px-5 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary-500 text-primary-500">
          1-on-1 Sessions
        </button>
        <button id="tab-group" onclick="switchTab('group')"
          class="px-5 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-neutral-600 hover:text-primary-500">
          Group Sessions
        </button>
      </div>

      <!-- 1-on-1 Pane -->
      <div id="pane-1on1">
        <div id="mentorBookingsContainer" class="space-y-6">
          <div class="text-center py-8 text-gray-500">
            <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
            <p>Loading your scheduled sessions...</p>
          </div>
        </div>
        <div id="emptyState" class="hidden text-center py-16">
          <div class="w-24 h-24 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-calendar-times text-neutral-400 text-3xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-neutral-800 mb-2 font-heading">No Confirmed Sessions</h3>
          <p class="text-neutral-600 mb-6">Accept pending requests to see them here.</p>
          <button onclick="window.location.href='/view-requests/<%= mentorId %>'" class="bg-primary-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors">
            <i class="fas fa-inbox mr-2"></i>View Requests
          </button>
        </div>
      </div>

      <!-- Group Sessions Pane -->
      <div id="pane-group" class="hidden">
        <!-- Create Group Session Form -->
        <div id="groupCreateSection" class="bg-white rounded-2xl shadow-md border border-neutral-100 p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-neutral-800 font-heading"><i class="fas fa-plus-circle text-indigo-500 mr-2"></i>Create Group Session</h2>
            <button onclick="toggleCreateForm()" id="toggleCreateBtn" class="text-sm text-primary-500 hover:text-primary-600 font-medium">Show Form</button>
          </div>
          <div id="createGroupForm" class="hidden">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-neutral-700 mb-1">Session Title *</label>
                <input id="gs_title" type="text" placeholder="e.g. Intro to Product Management"
                  class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400" />
              </div>
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-neutral-700 mb-1">Description</label>
                <textarea id="gs_description" placeholder="What will you cover in this session?"
                  class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm resize-none h-20 focus:outline-none focus:ring-2 focus:ring-primary-400"></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1">Date *</label>
                <input id="gs_date" type="date" class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400" />
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1">Time *</label>
                <input id="gs_time" type="time" class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400" />
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1">Max Mentees</label>
                <input id="gs_max" type="number" value="10" min="2" max="50"
                  class="w-full border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400" />
              </div>
            </div>
            <button onclick="createGroupSession()" class="bg-indigo-500 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-indigo-600 transition-colors text-sm">
              <i class="fas fa-plus mr-2"></i>Create Session
            </button>
          </div>
        </div>

        <div id="groupSessionsList" class="space-y-4">
          <div class="text-center py-8 text-gray-500">
            <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
            <p>Loading group sessions...</p>
          </div>
        </div>
        <div id="emptyGroupState" class="hidden text-center py-12">
          <div class="w-20 h-20 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-users text-indigo-400 text-2xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-neutral-800 font-heading mb-2">No Group Sessions Yet</h3>
          <p class="text-neutral-500 text-sm">Use the form above to create your first group session.</p>
        </div>
      </div>
    </main>

    <script>
      const mentorId = '<%= mentorId %>';

      // ── Tabs ──────────────────────────────────────────────────────────────────
      function switchTab(tab) {
        ['1on1','group'].forEach(t => {
          document.getElementById(`pane-${t}`).classList.toggle('hidden', t !== tab);
          const btn = document.getElementById(`tab-${t}`);
          if (t === tab) { btn.classList.add('border-primary-500','text-primary-500'); btn.classList.remove('border-transparent','text-neutral-600'); }
          else           { btn.classList.remove('border-primary-500','text-primary-500'); btn.classList.add('border-transparent','text-neutral-600'); }
        });
        if (tab === 'group') loadGroupSessions();
        // Handle hash
        if (tab === 'group' && window.location.hash === '#group-sessions') {}
      }

      document.addEventListener('DOMContentLoaded', () => {
        loadBookings();
        setupMobileMenu();
        if (window.location.hash === '#group-sessions') switchTab('group');
      });

      // ── 1-on-1 Sessions ───────────────────────────────────────────────────────
      async function loadBookings() {
        try {
          const response = await fetch(`/mentor-sessions/${mentorId}`);
          const data     = await response.json();
          if (data.success) displayBookings(data.sessions.filter(s => s.status === 'accepted'));
          else showError('Failed to load bookings');
        } catch (error) {
          showError('Failed to load your scheduled sessions');
        }
      }

      function displayBookings(sessions) {
        const container  = document.getElementById('mentorBookingsContainer');
        const emptyState = document.getElementById('emptyState');

        if (sessions.length === 0) {
          container.innerHTML = '';
          emptyState.classList.remove('hidden');
          return;
        }

        sessions.sort((a, b) => new Date(a.date + ' ' + a.time) - new Date(b.date + ' ' + b.time));

        container.innerHTML = sessions.map(session => {
          const initials = session.menteeName.split(' ').map(n => n[0]).join('');
          const colors   = ['from-blue-400 to-blue-600','from-green-400 to-green-600','from-purple-400 to-purple-600','from-pink-400 to-pink-600','from-orange-400 to-orange-600'];
          const color    = colors[Math.abs(session.id.charCodeAt(0)) % colors.length];
          const isPast   = new Date(session.date + ' ' + session.time) < new Date();

          return `
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-neutral-100 hover:shadow-xl transition-all ${isPast ? 'opacity-75' : ''}">
              <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-gradient-to-br ${color} rounded-full flex items-center justify-center shadow-lg flex-shrink-0">
                    <span class="text-white text-xl font-bold">${initials}</span>
                  </div>
                  <div>
                    <h3 class="text-xl font-semibold text-neutral-800 font-heading">${session.menteeName}</h3>
                    <p class="text-neutral-500 text-sm"><i class="fas fa-calendar mr-2"></i>${formatDate(session.date)} at ${formatTime(session.time)}</p>
                    <p class="text-neutral-500 text-sm"><i class="fas fa-clock mr-2"></i>${isPast ? 'Completed' : 'Upcoming'}</p>
                  </div>
                </div>
                <div class="flex-1 lg:ml-8">
                  ${session.message ? `<p class="text-neutral-600 text-sm mb-3"><span class="font-semibold">Topic:</span> ${session.message}</p>` : ''}
                  <div class="flex gap-2 flex-wrap">
                    <span class="px-3 py-1 rounded-full text-sm font-medium ${isPast ? 'bg-gray-100 text-gray-700' : 'bg-green-100 text-green-800'}">
                      <i class="fas ${isPast ? 'fa-check' : 'fa-check-circle'} mr-1"></i>${isPast ? 'Completed' : 'Confirmed'}
                    </span>
                    <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium"><i class="fas fa-video mr-1"></i>Video Call</span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  ${!isPast ? `
                    <button onclick="joinVideoCall('${session.id}')" class="bg-primary-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-primary-600 text-sm flex items-center justify-center">
                      <i class="fas fa-video mr-2"></i>Join Video Call
                    </button>` : `
                    <button onclick="openChat('${session.menteeId}')" class="border border-primary-500 text-primary-500 px-5 py-2 rounded-lg font-medium hover:bg-primary-50 text-sm flex items-center justify-center">
                      <i class="fas fa-comments mr-2"></i>Message Mentee
                    </button>`}
                </div>
              </div>
            </div>`;
        }).join('');
      }

      function joinVideoCall(sessionId) {
        window.open(`/video-call/${sessionId}?userId=${mentorId}`, '_blank');
      }

      function openChat(menteeId) {
        window.location.href = `/chat/${mentorId}/${menteeId}`;
      }

      // ── Group Sessions ─────────────────────────────────────────────────────────
      function toggleCreateForm() {
        const form = document.getElementById('createGroupForm');
        const btn  = document.getElementById('toggleCreateBtn');
        const hidden = form.classList.toggle('hidden');
        btn.textContent = hidden ? 'Show Form' : 'Hide Form';
      }

      async function createGroupSession() {
        const title = document.getElementById('gs_title').value.trim();
        const desc  = document.getElementById('gs_description').value.trim();
        const date  = document.getElementById('gs_date').value;
        const time  = document.getElementById('gs_time').value;
        const max   = document.getElementById('gs_max').value;

        if (!title || !date || !time) return alert('Title, date and time are required.');

        try {
          const res  = await fetch('/create-group-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mentorId, title, description: desc, date, time, maxMentees: max }),
          });
          const data = await res.json();
          if (data.success) {
            // Clear form
            ['gs_title','gs_description','gs_date','gs_time'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('gs_max').value = '10';
            toggleCreateForm();
            loadGroupSessions();
          } else {
            alert(data.message || 'Failed to create session.');
          }
        } catch (err) {
          alert('Error creating session.');
        }
      }

      async function loadGroupSessions() {
        const list       = document.getElementById('groupSessionsList');
        const emptyState = document.getElementById('emptyGroupState');
        list.innerHTML = `<div class="text-center py-8 text-gray-500"><i class="fas fa-spinner fa-spin text-3xl mb-3"></i><p>Loading...</p></div>`;

        try {
          const res  = await fetch(`/group-sessions/mentor/${mentorId}`);
          const data = await res.json();
          if (!data.success || data.groupSessions.length === 0) {
            list.innerHTML = '';
            emptyState.classList.remove('hidden');
            return;
          }
          emptyState.classList.add('hidden');
          list.innerHTML = data.groupSessions.map(gs => {
            const isPast    = new Date(gs.date + ' ' + gs.time) < new Date();
            const accepted  = gs.participants.filter(p => p.status === 'accepted');
            const statusBadge = gs.status === 'cancelled'
              ? '<span class="bg-red-100 text-red-700 px-2 py-0.5 rounded-full text-xs">Cancelled</span>'
              : isPast
                ? '<span class="bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full text-xs">Past</span>'
                : '<span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full text-xs">Upcoming</span>';

            return `
              <div class="bg-white rounded-2xl shadow-md p-6 border border-neutral-100 hover:shadow-lg transition-all ${gs.status === 'cancelled' ? 'opacity-60' : ''}">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2 flex-wrap">
                      <span class="bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-full text-xs font-medium"><i class="fas fa-users mr-1"></i>Group</span>
                      ${statusBadge}
                    </div>
                    <h3 class="text-lg font-semibold text-neutral-800 font-heading mb-1">${gs.title}</h3>
                    ${gs.description ? `<p class="text-neutral-500 text-sm mb-2">${gs.description}</p>` : ''}
                    <p class="text-neutral-500 text-sm"><i class="fas fa-calendar mr-2"></i>${formatDate(gs.date)} at ${formatTime(gs.time)}</p>
                    <p class="text-neutral-400 text-xs mt-1"><i class="fas fa-users mr-1"></i>${accepted.length}/${gs.maxMentees} enrolled</p>
                    ${accepted.length > 0 ? `
                      <div class="mt-2 flex flex-wrap gap-1">
                        ${accepted.map(p => `<span class="bg-neutral-100 text-neutral-600 text-xs px-2 py-0.5 rounded-full">${p.menteeName}</span>`).join('')}
                      </div>` : ''}
                  </div>
                  <div class="flex flex-col gap-2 min-w-max">
                    ${gs.status !== 'cancelled' && !isPast ? `
                      <button onclick="joinGroupCall('${gs.id}')" class="bg-primary-500 text-white px-4 py-2 rounded-lg font-medium hover:bg-primary-600 text-sm flex items-center justify-center">
                        <i class="fas fa-video mr-2"></i>Start Call
                      </button>
                      <button onclick="cancelGroupSession('${gs.id}', this)" class="border border-red-300 text-red-500 px-4 py-2 rounded-lg font-medium hover:bg-red-50 text-sm flex items-center justify-center">
                        <i class="fas fa-times mr-2"></i>Cancel
                      </button>` : ''}
                    ${isPast && gs.status !== 'cancelled' ? `
                      <span class="bg-neutral-100 text-neutral-500 px-3 py-1 rounded-lg text-xs text-center">Completed</span>` : ''}
                  </div>
                </div>
              </div>`;
          }).join('');
        } catch (err) {
          list.innerHTML = '<p class="text-red-500 text-center py-4">Failed to load group sessions.</p>';
        }
      }

      function joinGroupCall(groupSessionId) {
        window.open(`/group-video-call/${groupSessionId}?userId=${mentorId}`, '_blank');
      }

      async function cancelGroupSession(groupSessionId, btn) {
        if (!confirm('Are you sure you want to cancel this group session?')) return;
        btn.disabled = true;
        try {
          const res  = await fetch('/cancel-group-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ groupSessionId, mentorId }),
          });
          const data = await res.json();
          if (data.success) loadGroupSessions();
          else alert(data.message || 'Failed to cancel.');
        } catch (err) {
          alert('Error cancelling session.');
          btn.disabled = false;
        }
      }

      // ── Shared helpers ────────────────────────────────────────────────────────
      function formatDate(d) {
        return new Date(d).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
      }
      function formatTime(t) {
        const [h, m] = t.split(':');
        const hr = parseInt(h);
        return `${hr % 12 || 12}:${m} ${hr >= 12 ? 'PM' : 'AM'}`;
      }
      function showError(msg) {
        document.getElementById('mentorBookingsContainer').innerHTML = `
          <div class="text-center py-8 text-red-500">
            <i class="fas fa-exclamation-circle text-3xl mb-3"></i><p>${msg}</p>
            <button onclick="loadBookings()" class="mt-4 text-primary-500 font-medium"><i class="fas fa-refresh mr-2"></i>Try Again</button>
          </div>`;
      }
      async function logout() {
        const res = await fetch("/logout", { method: "POST" });
        if (res.ok) window.location.href = "/login";
      }
      function setupMobileMenu() {
        const btn  = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => menu.classList.toggle('hidden'));
        document.addEventListener('click', e => {
          if (!btn.contains(e.target) && !menu.contains(e.target)) menu.classList.add('hidden');
        });
      }
    </script>
  </body>
</html>