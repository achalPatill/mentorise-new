<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Video Call - Mentorise</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: { primary: { 50:"#f0f4ff",500:"#3A5BA0",600:"#2F3C7E" } } } }
    };
  </script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"/>
  <style>
    * { -webkit-tap-highlight-color: transparent; box-sizing: border-box; }
    body { background:#0f1117; font-family:'Roboto',sans-serif; overflow:hidden; touch-action:manipulation; }

    #localVideo { width:100%; height:100%; object-fit:cover; border-radius:10px; background:#1a1d2e; transform:scaleX(-1); }
    .pip-container {
      position:absolute; top:12px; right:12px; z-index:10;
      width:clamp(90px,22vw,160px); height:clamp(65px,16vw,115px);
      border:2px solid #3A5BA0; border-radius:10px; overflow:hidden;
      box-shadow:0 4px 15px rgba(0,0,0,.5); cursor:move; user-select:none;
    }
    .pip-label { position:absolute; bottom:4px; left:6px; background:rgba(0,0,0,.55); color:#fff; font-size:10px; padding:1px 5px; border-radius:4px; pointer-events:none; }

    /* 1-on-1 */
    #remoteVideo { width:100%; height:100%; object-fit:cover; border-radius:16px; background:#1a1d2e; transform:scaleX(-1); }

    /* Group grid */
    #groupGrid {
      width:100%; height:100%; padding:8px; gap:8px;
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      align-content:start;
      overflow-y:auto;
    }
    .peer-tile { position:relative; background:#1a1d2e; border-radius:12px; overflow:hidden; aspect-ratio:16/9; min-height:110px; }
    .peer-tile video { width:100%; height:100%; object-fit:cover; transform:scaleX(-1); display:block; }
    .peer-tile .peer-label { position:absolute; bottom:6px; left:8px; background:rgba(0,0,0,.6); color:#fff; font-size:11px; padding:2px 7px; border-radius:5px; pointer-events:none; }
    .peer-tile .peer-avatar { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#1a1d2e; }
    .peer-tile .peer-avatar .initials { width:56px; height:56px; border-radius:50%; background:#3A5BA0; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.4rem; font-weight:700; }
    .peer-tile .peer-avatar p { color:#9ca3af; font-size:12px; margin-top:6px; }

    .ctrl { width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;font-size:18px;border:none;outline:none; }
    @media(max-width:480px){.ctrl{width:44px;height:44px;font-size:16px;}.ctrl.end-btn{width:58px;height:58px;}}
    .ctrl:hover{transform:scale(1.08);}.ctrl:active{transform:scale(0.95);}
    .pulse{animation:pulse 2s infinite;}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
    #endedScreen{display:none;position:fixed;inset:0;background:#0f1117;z-index:100;flex-direction:column;align-items:center;justify-content:center;}
    #endedScreen.show{display:flex;}
    .timer{font-variant-numeric:tabular-nums;}
    #chatPanel{transition:transform .3s ease;}#chatPanel.hidden{display:none;}
    .controls-bar{background:rgba(15,17,23,.97);padding:10px 0 max(10px,env(safe-area-inset-bottom));}
  </style>
</head>
<body class="h-screen flex flex-col" style="height:100dvh">

  <!-- TOP BAR -->
  <div class="flex items-center justify-between px-4 py-2 z-10 flex-shrink-0" style="background:rgba(15,17,23,.95)">
    <div class="flex items-center space-x-2 min-w-0">
      <span class="text-white font-bold text-base" style="font-family:Poppins;white-space:nowrap">Mentorise</span>
      <span class="text-gray-400 text-sm hidden sm:inline">|</span>
      <span class="text-gray-300 text-xs sm:text-sm truncate hidden sm:block">
        <% if (isGroupCall) { %>Group: <strong><%= otherUserName %></strong>
        <% } else { %>Session with <strong><%= otherUserName %></strong><% } %>
      </span>
    </div>
    <div class="flex items-center space-x-2 flex-shrink-0">
      <span id="peerCount" class="text-gray-400 text-xs hidden"><i class="fas fa-users mr-1"></i><span id="peerCountNum">1</span></span>
      <span id="callTimer" class="timer text-green-400 text-xs font-mono hidden">00:00</span>
      <span id="statusBadge" class="text-yellow-400 text-xs px-2 py-1 rounded-full border border-yellow-400 whitespace-nowrap">
        <i class="fas fa-circle-notch fa-spin mr-1"></i><span class="hidden sm:inline">Connecting</span>
      </span>
    </div>
  </div>

  <!-- VIDEO AREA -->
  <div class="flex-1 relative px-2 pb-1 min-h-0">

    <!-- 1-on-1 layout -->
    <div id="oneOnOneArea" class="w-full h-full rounded-2xl overflow-hidden relative" style="background:#1a1d2e;<% if(isGroupCall){%>display:none;<%}%>">
      <video id="remoteVideo" autoplay playsinline></video>
      <div id="waitingOverlay" class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl" style="background:#1a1d2e;">
        <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-blue-600 flex items-center justify-center mb-4 pulse">
          <span class="text-white text-2xl sm:text-3xl font-bold"><%= otherUserName.split(' ').map(function(n){return n[0]}).join('') %></span>
        </div>
        <p class="text-white text-lg sm:text-xl font-semibold mb-2"><%= otherUserName %></p>
        <p class="text-gray-400 text-sm pulse">Waiting for them to join...</p>
      </div>
      <div class="absolute bottom-3 left-3 bg-black bg-opacity-50 px-3 py-1 rounded-lg">
        <span class="text-white text-xs sm:text-sm"><%= otherUserName %></span>
      </div>
    </div>

    <!-- Group layout -->
    <div id="groupArea" class="w-full h-full rounded-2xl overflow-hidden relative" style="background:#1a1d2e;<% if(!isGroupCall){%>display:none;<%}%>">
      <div id="groupGrid"></div>
      <div id="groupWaitingOverlay" class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl" style="background:#1a1d2e;">
        <div class="w-16 h-16 rounded-full bg-indigo-600 flex items-center justify-center mb-4 pulse">
          <i class="fas fa-users text-white text-2xl"></i>
        </div>
        <p class="text-white text-lg font-semibold mb-2"><%= otherUserName %></p>
        <p class="text-gray-400 text-sm pulse">Waiting for others to join...</p>
      </div>
    </div>

    <!-- Local PiP -->
    <div class="pip-container" id="pipContainer">
      <video id="localVideo" autoplay playsinline muted></video>
      <div class="pip-label">You</div>
    </div>
  </div>

  <!-- CONTROLS -->
  <div class="controls-bar flex items-center justify-center space-x-3 sm:space-x-4 flex-shrink-0">
    <button id="muteBtn"   onclick="toggleMute()"        class="ctrl" style="background:#2d3142"><i id="muteIcon"   class="fas fa-microphone text-white"></i></button>
    <button id="camBtn"    onclick="toggleCamera()"      class="ctrl" style="background:#2d3142"><i id="camIcon"    class="fas fa-video text-white"></i></button>
    <button                onclick="endCall()"           class="ctrl end-btn" style="background:#e63946;width:62px;height:62px"><i class="fas fa-phone-slash text-white text-xl"></i></button>
    <button id="screenBtn" onclick="toggleScreenShare()" class="ctrl hidden sm:flex" style="background:#2d3142"><i id="screenIcon" class="fas fa-desktop text-white"></i></button>
    <button                onclick="toggleChat()"        class="ctrl" style="background:#2d3142"><i class="fas fa-comment text-white"></i></button>
  </div>

  <!-- CALL ENDED SCREEN -->
  <div id="endedScreen">
    <div class="text-center px-6">
      <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full flex items-center justify-center mx-auto mb-6" style="background:rgba(230,57,70,.2)">
        <i class="fas fa-phone-slash text-red-400 text-3xl sm:text-4xl"></i>
      </div>
      <h2 class="text-white text-2xl sm:text-3xl font-bold mb-2" style="font-family:Poppins">Call Ended</h2>
      <p class="text-gray-400 mb-1 text-sm sm:text-base">Session with <strong class="text-white"><%= otherUserName %></strong> completed</p>
      <p id="durationLabel" class="text-gray-500 text-sm mb-8"></p>
      <p class="text-gray-500 text-sm mb-4">Redirecting in <span id="countdown" class="text-blue-400 font-bold">5</span>s...</p>
      <button onclick="redirectNow()" class="bg-blue-600 text-white px-6 sm:px-8 py-3 rounded-xl font-semibold hover:bg-blue-700 transition-colors text-sm sm:text-base">Go Back Now</button>
    </div>
  </div>

  <!-- CHAT PANEL -->
  <div id="chatPanel" class="hidden fixed right-0 top-0 h-full w-72 sm:w-80 flex flex-col z-50" style="background:#1a1d2e;border-left:1px solid #2d3142">
    <div class="flex items-center justify-between px-4 py-3 border-b" style="border-color:#2d3142">
      <span class="text-white font-semibold text-sm">In-call Chat</span>
      <button onclick="toggleChat()" class="text-gray-400 hover:text-white p-1"><i class="fas fa-times"></i></button>
    </div>
    <div id="chatMsgs" class="flex-1 overflow-y-auto px-4 py-3 space-y-2 text-sm"></div>
    <div class="flex gap-2 px-3 py-3 border-t" style="border-color:#2d3142;padding-bottom:max(12px,env(safe-area-inset-bottom))">
      <input id="chatInput" type="text" placeholder="Type a message..." maxlength="300"
        class="flex-1 bg-transparent border border-gray-600 text-white rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-500"
        onkeydown="if(event.key==='Enter')sendChat()"/>
      <button onclick="sendChat()" class="bg-blue-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-blue-700">
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const SESSION_ID   = '<%- sessionId %>';
    const MY_ID        = '<%- currentUserId %>';
    const MY_NAME      = '<%- currentUserName %>';
    const OTHER_ID     = '<%- otherUserId %>';
    const OTHER_NAME   = '<%- otherUserName %>';
    const REDIRECT_URL = '<%- redirectUrl %>';
    const IS_GROUP     = <%- isGroupCall %>;
    const ROOM         = 'video_' + SESSION_ID;

    let localStream  = null;
    let isMuted      = false;
    let isCamOff     = false;
    let isSharing    = false;
    let origTrack    = null;
    let timerInterval = null;
    let callSecs     = 0;
    let timerStarted = false;

    // peers[socketId] = { pc, userId, userName, tileEl, videoEl }
    const peers = {};

    const socket = io();

    // ── Init ──────────────────────────────────────────────────────────────────
    async function init() {
      try {
        localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
      } catch(e) {
        try {
          localStream = await navigator.mediaDevices.getUserMedia({ video: false, audio: true });
          isCamOff = true;
          document.getElementById('camIcon').className = 'fas fa-video-slash text-white';
          document.getElementById('camBtn').style.background = '#e63946';
          showBanner('Camera unavailable — audio only.', 'yellow');
        } catch(e2) {
          showBanner('Cannot access microphone. Allow permissions and reload.', 'red');
          return;
        }
      }
      document.getElementById('localVideo').srcObject = localStream;
      socket.emit('join-video-room', { room: ROOM, userId: MY_ID, userName: MY_NAME });
      makePipDraggable();
    }

    // ── Socket events ─────────────────────────────────────────────────────────

    // Server tells us who is already in the room when we join
    socket.on('video-room-peers', async ({ peers: existingPeers }) => {
      for (const p of existingPeers) {
        if (p.socketId === socket.id || p.userId === MY_ID) continue;
        await createPC(p.socketId, p.userId, p.userName || p.userId, true /* we initiate */);
      }
      updateUI();
    });

    // Someone joined AFTER us — they will send offers; we just prepare a PC slot
    socket.on('video-user-joined', async ({ userId, userName, socketId }) => {
      if (userId === MY_ID || socketId === socket.id) return;
      if (!peers[socketId]) {
        await createPC(socketId, userId, userName, false /* they initiate */);
      }
      updateUI();
    });

    // Signaling
    socket.on('video-signal', async ({ from, fromSocketId, type, sdp, candidate }) => {
      const sid = fromSocketId || from;
      if (sid === socket.id) return;

      if (!peers[sid]) {
        // Offer from unknown peer — create PC and accept
        if (type === 'offer') {
          await createPC(sid, sid, 'Peer', false);
        } else { return; }
      }

      const pc = peers[sid].pc;

      if (type === 'offer') {
        if (pc.signalingState !== 'stable') {
          await Promise.all([
            pc.setLocalDescription({ type: 'rollback' }),
            pc.setRemoteDescription(new RTCSessionDescription(sdp)),
          ]);
        } else {
          await pc.setRemoteDescription(new RTCSessionDescription(sdp));
        }
        const answer = await pc.createAnswer();
        await pc.setLocalDescription(answer);
        socket.emit('video-signal', {
          room: ROOM, toSocketId: sid,
          from: MY_ID, fromSocketId: socket.id,
          type: 'answer', sdp: answer,
        });
      } else if (type === 'answer') {
        if (pc.signalingState === 'have-local-offer') {
          await pc.setRemoteDescription(new RTCSessionDescription(sdp));
        }
      } else if (type === 'ice' && candidate) {
        try { await pc.addIceCandidate(new RTCIceCandidate(candidate)); } catch(e) {}
      }
    });

    // Peer left
    socket.on('video-user-left', ({ userId: leftId, socketId: leftSid }) => {
      const sid = leftSid || Object.keys(peers).find(s => peers[s].userId === leftId);
      if (sid) closePeer(sid);
      updateUI();
      if (!IS_GROUP) {
        if (localStream) localStream.getTracks().forEach(t => t.stop());
        clearInterval(timerInterval);
        showEndedScreen(true);
      }
    });

    // ── WebRTC ────────────────────────────────────────────────────────────────
    const ICE_SERVERS = [
      { urls: 'stun:stun.l.google.com:19302' },
      { urls: 'stun:stun1.l.google.com:19302' },
      { urls: 'stun:stun.cloudflare.com:3478' },
      { urls: 'turn:openrelay.metered.ca:80',  username: 'openrelayproject', credential: 'openrelayproject' },
      { urls: 'turn:openrelay.metered.ca:443', username: 'openrelayproject', credential: 'openrelayproject' },
      { urls: 'turn:openrelay.metered.ca:443?transport=tcp', username: 'openrelayproject', credential: 'openrelayproject' },
    ];

    async function createPC(socketId, userId, userName, isInitiator) {
      if (peers[socketId]) return peers[socketId].pc;

      const pc = new RTCPeerConnection({ iceServers: ICE_SERVERS, iceCandidatePoolSize: 10 });

      // Prepare video element
      let tileEl = null, videoEl;
      if (IS_GROUP) {
        const t = createGroupTile(socketId, userName);
        tileEl = t.tileEl; videoEl = t.videoEl;
      } else {
        videoEl = document.getElementById('remoteVideo');
      }

      peers[socketId] = { pc, userId, userName, tileEl, videoEl };

      // Add local tracks to the connection
      if (localStream) localStream.getTracks().forEach(t => pc.addTrack(t, localStream));

      pc.ontrack = e => {
        const streams = e.streams;
        if (streams && streams[0]) {
          videoEl.srcObject = streams[0];
        } else {
          // Fallback: build a MediaStream from the track
          if (!videoEl.srcObject) videoEl.srcObject = new MediaStream();
          videoEl.srcObject.addTrack(e.track);
        }
        videoEl.play().catch(() => {});

        // Hide avatar placeholder in group tile
        if (IS_GROUP && tileEl) {
          const av = tileEl.querySelector('.peer-avatar');
          if (av) av.style.display = 'none';
          hideGroupWaiting();
        } else if (!IS_GROUP) {
          document.getElementById('waitingOverlay').style.display = 'none';
          setStatus('green', 'Connected');
        }
        maybeStartTimer();
      };

      pc.onicecandidate = e => {
        if (e.candidate) {
          socket.emit('video-signal', {
            room: ROOM, toSocketId: socketId,
            from: MY_ID, fromSocketId: socket.id,
            type: 'ice', candidate: e.candidate,
          });
        }
      };

      pc.onconnectionstatechange = () => {
        console.log(`[${userName}] ${pc.connectionState}`);
        if (pc.connectionState === 'connected') {
          if (IS_GROUP) hideGroupWaiting();
          else { setStatus('green', 'Connected'); }
          maybeStartTimer();
        }
        if (pc.connectionState === 'failed') {
          try { if (pc.restartIce) pc.restartIce(); } catch(e) {}
        }
      };

      if (isInitiator) {
        const offer = await pc.createOffer();
        await pc.setLocalDescription(offer);
        socket.emit('video-signal', {
          room: ROOM, toSocketId: socketId,
          from: MY_ID, fromSocketId: socket.id,
          type: 'offer', sdp: offer,
        });
      }

      return pc;
    }

    function closePeer(socketId) {
      const entry = peers[socketId];
      if (!entry) return;
      try { entry.pc.close(); } catch(e) {}
      if (IS_GROUP && entry.tileEl && entry.tileEl.parentNode) entry.tileEl.remove();
      delete peers[socketId];
      if (IS_GROUP && Object.keys(peers).length === 0) {
        document.getElementById('groupWaitingOverlay').style.display = '';
      }
    }

    // ── Group tile helpers ────────────────────────────────────────────────────
    function getInitials(name) {
      return (name || '?').trim().split(/\s+/).map(n => n[0]).join('').toUpperCase().slice(0, 2);
    }

    function createGroupTile(socketId, userName) {
      const grid = document.getElementById('groupGrid');
      const tileEl = document.createElement('div');
      tileEl.className = 'peer-tile';
      tileEl.dataset.sid = socketId;

      const videoEl = document.createElement('video');
      videoEl.autoplay = true;
      videoEl.playsInline = true;

      const label = document.createElement('div');
      label.className = 'peer-label';
      label.textContent = userName;

      const avatarDiv = document.createElement('div');
      avatarDiv.className = 'peer-avatar';
      avatarDiv.innerHTML = `<div class="initials">${getInitials(userName)}</div><p class="pulse">Connecting…</p>`;

      tileEl.appendChild(videoEl);
      tileEl.appendChild(label);
      tileEl.appendChild(avatarDiv);
      grid.appendChild(tileEl);
      return { tileEl, videoEl };
    }

    function hideGroupWaiting() {
      const ov = document.getElementById('groupWaitingOverlay');
      if (ov) ov.style.display = 'none';
      const n = Object.keys(peers).length + 1;
      setStatus('green', n + ' in call');
    }

    function updateUI() {
      const n = Object.keys(peers).length + 1;
      if (IS_GROUP) {
        document.getElementById('peerCount').classList.remove('hidden');
        document.getElementById('peerCountNum').textContent = n;
      }
    }

    // ── Controls ──────────────────────────────────────────────────────────────
    function toggleMute() {
      isMuted = !isMuted;
      if (localStream) localStream.getAudioTracks().forEach(t => t.enabled = !isMuted);
      document.getElementById('muteIcon').className = isMuted ? 'fas fa-microphone-slash text-white' : 'fas fa-microphone text-white';
      document.getElementById('muteBtn').style.background = isMuted ? '#e63946' : '#2d3142';
    }

    function toggleCamera() {
      isCamOff = !isCamOff;
      if (localStream) localStream.getVideoTracks().forEach(t => t.enabled = !isCamOff);
      document.getElementById('camIcon').className = isCamOff ? 'fas fa-video-slash text-white' : 'fas fa-video text-white';
      document.getElementById('camBtn').style.background = isCamOff ? '#e63946' : '#2d3142';
    }

    async function toggleScreenShare() {
      if (!isSharing) {
        try {
          const ss = await navigator.mediaDevices.getDisplayMedia({ video: true });
          const st = ss.getVideoTracks()[0];
          origTrack = localStream.getVideoTracks()[0];
          Object.values(peers).forEach(({ pc }) => {
            const sender = pc.getSenders().find(s => s.track?.kind === 'video');
            if (sender) sender.replaceTrack(st);
          });
          document.getElementById('localVideo').srcObject = ss;
          isSharing = true;
          document.getElementById('screenIcon').className = 'fas fa-desktop text-yellow-400';
          st.onended = stopScreenShare;
        } catch(e) { console.error(e); }
      } else { stopScreenShare(); }
    }

    function stopScreenShare() {
      if (!origTrack) return;
      Object.values(peers).forEach(({ pc }) => {
        const sender = pc.getSenders().find(s => s.track?.kind === 'video');
        if (sender) sender.replaceTrack(origTrack);
      });
      document.getElementById('localVideo').srcObject = localStream;
      isSharing = false;
      document.getElementById('screenIcon').className = 'fas fa-desktop text-white';
      origTrack = null;
    }

    function endCall() {
      if (localStream) localStream.getTracks().forEach(t => t.stop());
      Object.keys(peers).forEach(sid => { try { peers[sid].pc.close(); } catch(e) {} });
      socket.emit('video-leave', { room: ROOM, userId: MY_ID, socketId: socket.id });
      clearInterval(timerInterval);
      showEndedScreen(false);
    }

    function maybeStartTimer() {
      if (timerStarted) return;
      timerStarted = true;
      const el = document.getElementById('callTimer');
      el.classList.remove('hidden');
      timerInterval = setInterval(() => {
        callSecs++;
        el.textContent = String(Math.floor(callSecs/60)).padStart(2,'0') + ':' + String(callSecs%60).padStart(2,'0');
      }, 1000);
    }

    function showEndedScreen(byPeer = false) {
      const s = document.getElementById('endedScreen');
      s.classList.add('show');
      if (byPeer) {
        s.querySelector('h2').textContent = 'Call Ended';
        s.querySelector('p').innerHTML = `<strong class="text-white">${OTHER_NAME}</strong> ended the session`;
      }
      if (callSecs > 0) {
        const m = Math.floor(callSecs/60), sec = callSecs%60;
        document.getElementById('durationLabel').textContent = 'Duration: ' + (m > 0 ? m + 'm ' : '') + sec + 's';
      }
      let c = 5;
      const el = document.getElementById('countdown');
      const iv = setInterval(() => { c--; el.textContent = c; if (c <= 0) { clearInterval(iv); redirectNow(); } }, 1000);
    }

    function redirectNow() { window.location.href = REDIRECT_URL; }

    function setStatus(color, text) {
      const el = document.getElementById('statusBadge');
      const cols = { green:'text-green-400 border-green-400', yellow:'text-yellow-400 border-yellow-400', red:'text-red-400 border-red-400' };
      const icons = { green:'fa-circle', yellow:'fa-circle-notch fa-spin', red:'fa-circle' };
      el.className = `${cols[color]} text-xs px-2 py-1 rounded-full border`;
      el.innerHTML = `<i class="fas ${icons[color]} mr-1"></i><span class="hidden sm:inline">${text}</span>`;
    }

    function toggleChat() { document.getElementById('chatPanel').classList.toggle('hidden'); }

    function sendChat() {
      const inp = document.getElementById('chatInput');
      const msg = inp.value.trim();
      if (!msg) return;
      socket.emit('video-chat-msg', { room: ROOM, sender: MY_NAME, message: msg });
      appendChat(MY_NAME, msg, true);
      inp.value = '';
    }

    socket.on('video-chat-msg', ({ sender, message }) => {
      if (sender !== MY_NAME) appendChat(sender, message, false);
    });

    function appendChat(sender, message, self) {
      const c = document.getElementById('chatMsgs');
      const d = document.createElement('div');
      d.className = self ? 'text-right' : 'text-left';
      d.innerHTML = `<span class="text-gray-400 text-xs">${self ? 'You' : sender}</span>
        <div class="inline-block px-3 py-2 rounded-xl text-sm mt-0.5 max-w-xs break-words ${self ? 'bg-blue-600 text-white' : 'bg-gray-700 text-white'}">${message}</div>`;
      c.appendChild(d);
      c.scrollTop = c.scrollHeight;
    }

    function makePipDraggable() {
      const pip = document.getElementById('pipContainer');
      let sx, sy, sl, st, drag = false;
      const onStart = (cx, cy) => { const r = pip.getBoundingClientRect(); sx=cx;sy=cy;sl=r.left;st=r.top;drag=true;pip.style.cursor='grabbing'; };
      const onMove  = (cx, cy) => { if(!drag)return; const vw=window.innerWidth,vh=window.innerHeight,pw=pip.offsetWidth,ph=pip.offsetHeight; pip.style.left=Math.max(0,Math.min(vw-pw,sl+(cx-sx)))+'px'; pip.style.top=Math.max(0,Math.min(vh-ph,st+(cy-sy)))+'px'; pip.style.right='auto'; };
      const onEnd   = () => { drag=false; pip.style.cursor='move'; };
      pip.addEventListener('mousedown', e => { onStart(e.clientX,e.clientY); e.preventDefault(); });
      document.addEventListener('mousemove', e => onMove(e.clientX,e.clientY));
      document.addEventListener('mouseup', onEnd);
      pip.addEventListener('touchstart', e => onStart(e.touches[0].clientX,e.touches[0].clientY), { passive:true });
      document.addEventListener('touchmove', e => { if(drag){onMove(e.touches[0].clientX,e.touches[0].clientY);e.preventDefault();} }, { passive:false });
      document.addEventListener('touchend', onEnd);
    }

    function showBanner(msg, color) {
      const b = document.createElement('div');
      b.className = `fixed top-16 left-1/2 -translate-x-1/2 z-50 px-4 py-2 rounded-lg text-white text-xs font-medium shadow-lg ${color==='yellow'?'bg-yellow-600':'bg-red-600'}`;
      b.textContent = msg;
      document.body.appendChild(b);
      setTimeout(() => b.remove(), 6000);
    }

    window.addEventListener('beforeunload', () => {
      if (localStream) localStream.getTracks().forEach(t => t.stop());
      socket.emit('video-leave', { room: ROOM, userId: MY_ID, socketId: socket.id });
    });

    init();
  </script>
</body>
</html>
