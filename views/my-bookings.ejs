<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Bookings - Mentorise</title>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: {
                50: "#f0f4ff",
                500: "#3A5BA0",
                600: "#2F3C7E",
                700: "#1e2a4a",
              },
              secondary: {
                50: "#fffbf0",
                500: "#FFD447",
                600: "#e6bf40",
              },
              neutral: {
                50: "#F5F7FA",
                100: "#e5e7eb",
                200: "#d1d5db",
                600: "#555555",
                800: "#222222",
              },
            },
            fontFamily: {
              heading: ["Poppins", "Inter", "sans-serif"],
              body: ["Roboto", "Open Sans", "sans-serif"],
            },
          },
        },
      };
    </script>

    <script src="/socket.io/socket.io.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  
  <body class="bg-neutral-50 font-body">
    <!-- Navigation Bar -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <a href="/mentee-home/<%= menteeId %>">
              <h1 class="text-2xl font-bold text-primary-500 font-heading">Mentorise</h1>
            </a>
          </div>

          <div class="hidden md:block">
            <div class="ml-10 flex items-baseline space-x-4">
              <a href="/mentee-home/<%= menteeId %>" class="text-neutral-800 hover:text-primary-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">Home</a>
              <a href="/mentee-profile/<%= menteeId %>" class="text-neutral-800 hover:text-primary-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">Profile</a>
              <a href="/my-bookings/<%= menteeId %>" class="text-primary-500 px-3 py-2 rounded-md text-sm font-medium">My Bookings</a>
            </div>
          </div>

          <div class="hidden md:block">
            <button onclick="logout()" class="text-neutral-800 hover:text-red-500 px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Logout
            </button>
          </div>

          <div class="md:hidden">
            <button id="mobile-menu-button" class="text-neutral-800 hover:text-primary-500 p-2">
              <i class="fas fa-bars text-xl"></i>
            </button>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
        <div class="px-2 pt-2 pb-3 space-y-1">
          <a href="/mentee-home/<%= menteeId %>" class="text-neutral-800 hover:text-primary-500 block px-3 py-2 rounded-md text-base font-medium">Home</a>
          <a href="/mentee-profile/<%= menteeId %>" class="text-neutral-800 hover:text-primary-500 block px-3 py-2 rounded-md text-base font-medium">Profile</a>
          <a href="/my-bookings/<%= menteeId %>" class="text-primary-500 block px-3 py-2 rounded-md text-base font-medium">My Bookings</a>
          <button onclick="logout()" class="text-neutral-800 hover:text-red-500 block px-3 py-2 rounded-md text-base font-medium w-full text-left">Logout</button>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Page Header -->
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-neutral-800 mb-4 font-heading">My Bookings</h1>
        <p class="text-xl text-neutral-600 max-w-3xl mx-auto">
          View your confirmed mentorship sessions and join your video calls.
        </p>
      </div>

      <!-- Tabs -->
      <div class="flex gap-2 mb-8 border-b border-neutral-200">
        <button id="tab-1on1" onclick="switchTab('1on1')"
          class="tab-btn active-tab px-5 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary-500 text-primary-500">
          1-on-1 Sessions
        </button>
        <button id="tab-group" onclick="switchTab('group')"
          class="tab-btn px-5 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-neutral-600 hover:text-primary-500">
          Group Sessions
        </button>
      </div>

      <!-- 1-on-1 Sessions Tab -->
      <div id="pane-1on1">
        <!-- Bookings Container -->
        <div id="menteeBookingsContainer" class="space-y-6">
          <div class="text-center py-8 text-gray-500">
            <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
            <p>Loading your bookings...</p>
          </div>
        </div>
        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-16">
          <div class="w-24 h-24 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-calendar-times text-neutral-400 text-3xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-neutral-800 mb-2 font-heading">No Bookings Yet</h3>
          <p class="text-neutral-600 mb-6">You don't have any confirmed sessions yet. Start by finding a mentor!</p>
          <button onclick="window.location.href='/mentor-directory?menteeId=<%= menteeId %>'" class="bg-primary-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors">
            <i class="fas fa-search mr-2"></i>Find Mentors
          </button>
        </div>
      </div>

      <!-- Group Sessions Tab -->
      <div id="pane-group" class="hidden">
        <div id="groupSessionsContainer" class="space-y-4">
          <div class="text-center py-8 text-gray-500">
            <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
            <p>Loading group sessions...</p>
          </div>
        </div>
        <div id="emptyGroupState" class="hidden text-center py-16">
          <div class="w-24 h-24 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-users text-neutral-400 text-3xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-neutral-800 mb-2 font-heading">No Group Sessions</h3>
          <p class="text-neutral-600">No group sessions are available right now. Check back later!</p>
        </div>
      </div>
    </main>

    <!-- Rating Modal -->
    <div id="ratingModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 px-4">
      <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full">
        <h2 class="text-2xl font-bold text-neutral-800 font-heading mb-1">Rate Your Session</h2>
        <p id="ratingModalSubtitle" class="text-neutral-500 text-sm mb-6">Share your experience with this mentor.</p>

        <div class="flex justify-center gap-3 mb-6" id="starRating">
          <% for(let i=1;i<=5;i++) { %>
          <button class="star-btn text-3xl text-neutral-300 hover:text-yellow-400 transition-colors" data-star="<%= i %>">★</button>
          <% } %>
        </div>

        <textarea id="reviewComment" placeholder="Leave a comment (optional)..."
          class="w-full border border-neutral-200 rounded-lg p-3 text-sm resize-none h-24 focus:outline-none focus:ring-2 focus:ring-primary-400 mb-5"></textarea>

        <div class="flex gap-3">
          <button onclick="closeRatingModal()" class="flex-1 border border-neutral-200 text-neutral-600 py-2 rounded-lg font-medium hover:bg-neutral-50">Cancel</button>
          <button onclick="submitReview()" class="flex-1 bg-primary-500 text-white py-2 rounded-lg font-medium hover:bg-primary-600">Submit Review</button>
        </div>
      </div>
    </div>

    <script>
      const menteeId = '<%= menteeId %>';
      let selectedRating = 0;
      let currentReviewSession = null;

      // ── Real-time session status updates (Socket.IO) ─────────────────────────
      const socket = io();

      socket.on(`session-update-${menteeId}`, ({ sessionId, status, mentorName }) => {
        const card = document.getElementById(`session-${sessionId}`);
        if (!card) {
          loadBookings();
          return;
        }

        const statusBadge = card.querySelector('.status-badge');
        if (statusBadge) {
          if (status === 'accepted') {
            statusBadge.className = 'status-badge bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-medium';
            statusBadge.textContent = 'Accepted';
          } else if (status === 'rejected') {
            statusBadge.className = 'status-badge bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-medium';
            statusBadge.textContent = 'Rejected';
          }
        }

        showToast(
          status === 'accepted'
            ? `\u2705 ${mentorName} accepted your session request!`
            : `${mentorName} has declined your session request.`,
          status === 'accepted' ? 'success' : 'error'
        );
      });

      // ── Tab switching ────────────────────────────────────────────────────────
      function switchTab(tab) {
        ['1on1','group'].forEach(t => {
          document.getElementById(`pane-${t}`).classList.toggle('hidden', t !== tab);
          const btn = document.getElementById(`tab-${t}`);
          if (t === tab) {
            btn.classList.add('border-primary-500','text-primary-500');
            btn.classList.remove('border-transparent','text-neutral-600');
          } else {
            btn.classList.remove('border-primary-500','text-primary-500');
            btn.classList.add('border-transparent','text-neutral-600');
          }
        });
        if (tab === 'group') loadGroupSessions();
      }

      // ── 1-on-1 Bookings ──────────────────────────────────────────────────────
      document.addEventListener('DOMContentLoaded', () => {
        loadBookings();
        setupMobileMenu();
      });

      async function loadBookings() {
        try {
          const response = await fetch(`/mentee-sessions/${menteeId}`);
          const data = await response.json();
          if (data.success) displayBookings(data.sessions);
          else showError('Failed to load bookings');
        } catch (error) {
          showError('Failed to load your bookings');
        }
      }

      async function displayBookings(sessions) {
        const container  = document.getElementById('menteeBookingsContainer');
        const emptyState = document.getElementById('emptyState');

        if (sessions.length === 0) {
          container.innerHTML = '';
          emptyState.classList.remove('hidden');
          return;
        }

        sessions.sort((a, b) => {
          const order = { accepted: 0, pending: 1, rejected: 2 };
          return order[a.status] - order[b.status];
        });

        // Check which sessions already have a review
        const reviewChecks = await Promise.all(
          sessions.filter(s => s.status === 'accepted').map(s =>
            fetch(`/check-review/${s.id}`).then(r => r.json()).then(d => [s.id, d.hasReview])
          )
        );
        const reviewedSessions = new Set(reviewChecks.filter(([,has]) => has).map(([id]) => id));

        container.innerHTML = sessions.map(session => {
          const initials = session.mentorName.split(' ').map(n => n[0]).join('');
          const colors   = ['from-blue-400 to-blue-600','from-green-400 to-green-600','from-purple-400 to-purple-600','from-pink-400 to-pink-600','from-orange-400 to-orange-600'];
          const color    = colors[Math.abs(session.id.charCodeAt(0)) % colors.length];

          const isPast = new Date(session.date + ' ' + session.time) < new Date();
          const statusConfig = {
            pending:  { color: 'bg-yellow-100 text-yellow-800', icon: 'fa-clock',        text: 'Pending'   },
            accepted: { color: 'bg-green-100 text-green-800',   icon: 'fa-check-circle', text: 'Confirmed' },
            rejected: { color: 'bg-red-100 text-red-800',       icon: 'fa-times-circle', text: 'Rejected'  }
          };
          const config = statusConfig[session.status] || statusConfig.pending;
          const cardOpacity = session.status === 'rejected' || isPast ? 'opacity-75' : '';
          const alreadyReviewed = reviewedSessions.has(session.id);

          return `
            <div id="session-${session.id}" class="bg-white rounded-2xl shadow-lg p-6 border border-neutral-100 hover:shadow-xl transition-all duration-300 ${cardOpacity}">
              <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                <div class="flex items-center space-x-4">
                  <div class="w-16 h-16 bg-gradient-to-br ${color} rounded-full flex items-center justify-center shadow-lg flex-shrink-0">
                    <span class="text-white text-xl font-bold">${initials}</span>
                  </div>
                  <div>
                    <h3 class="text-xl font-semibold text-neutral-800 font-heading">${session.mentorName}</h3>
                    <p class="text-neutral-500 text-sm"><i class="fas fa-calendar mr-2"></i>${formatDate(session.date)} at ${formatTime(session.time)}</p>
                    <p class="text-neutral-500 text-sm"><i class="fas fa-clock mr-2"></i>Requested ${getTimeAgo(session.createdAt)}</p>
                  </div>
                </div>

                <div class="flex-1 lg:ml-8">
                  ${session.message ? `<div class="mb-3"><h4 class="font-semibold text-neutral-800 mb-1 text-sm">Topic:</h4><p class="text-neutral-600 text-sm">${session.message}</p></div>` : ''}
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="status-badge px-3 py-1 rounded-full text-sm font-medium ${config.color}">
                      <i class="fas ${config.icon} mr-1"></i>${config.text}
                    </span>
                    ${session.status === 'accepted' ? `<span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium"><i class="fas fa-video mr-1"></i>Video Call</span>` : ''}
                  </div>
                </div>

                <div class="flex flex-col gap-2">
                  ${session.status === 'accepted' ? `
                    ${!isPast ? `
                      <button onclick="joinVideoCall('${session.id}')" class="bg-primary-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-primary-600 transition-colors flex items-center justify-center text-sm">
                        <i class="fas fa-video mr-2"></i>Join Video Call
                      </button>
                    ` : (
                      alreadyReviewed
                        ? `<div class="bg-green-50 border border-green-200 rounded-lg p-2 text-center text-xs text-green-700"><i class="fas fa-check-circle mr-1"></i>Reviewed</div>`
                        : `<button onclick="openRatingModal('${session.id}','${String(session.mentorId)}','${session.mentorName}')" class="border border-yellow-400 text-yellow-600 px-5 py-2 rounded-lg font-medium hover:bg-yellow-50 transition-colors text-sm flex items-center justify-center"><i class="fas fa-star mr-2"></i>Rate Session</button>`
                    )}
                  ` : session.status === 'pending' ? `
                    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3 text-center">
                      <p class="text-sm text-yellow-800"><i class="fas fa-hourglass-half mr-2"></i>Awaiting approval</p>
                    </div>
                  ` : `
                    <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-center">
                      <p class="text-sm text-red-700"><i class="fas fa-times-circle mr-2"></i>Request was declined</p>
                    </div>
                  `}
                </div>
              </div>
            </div>`;
        }).join('');
      }

      // ── Group Sessions ────────────────────────────────────────────────────────
      async function loadGroupSessions() {
        const container  = document.getElementById('groupSessionsContainer');
        const emptyState = document.getElementById('emptyGroupState');
        container.innerHTML = `<div class="text-center py-8 text-gray-500"><i class="fas fa-spinner fa-spin text-3xl mb-3"></i><p>Loading...</p></div>`;

        try {
          const res  = await fetch(`/group-sessions/available/${menteeId}`);
          const data = await res.json();
          if (!data.success || data.groupSessions.length === 0) {
            container.innerHTML = '';
            emptyState.classList.remove('hidden');
            return;
          }

          emptyState.classList.add('hidden');
          container.innerHTML = data.groupSessions.map(gs => {
            const spotsLeft  = gs.maxMentees - gs.participantCount;
            const isFull     = spotsLeft <= 0;
            const joined     = gs.alreadyJoined;
            const isPast     = new Date(gs.date + ' ' + gs.time) < new Date();
            return `
              <div class="bg-white rounded-2xl shadow-md p-6 border border-neutral-100 hover:shadow-lg transition-all">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-full text-xs font-medium"><i class="fas fa-users mr-1"></i>Group</span>
                      ${isPast ? '<span class="bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full text-xs">Past</span>' : '<span class="bg-green-50 text-green-600 px-2 py-0.5 rounded-full text-xs">Upcoming</span>'}
                    </div>
                    <h3 class="text-lg font-semibold text-neutral-800 font-heading">${gs.title}</h3>
                    <p class="text-neutral-500 text-sm mb-1">By <strong>${gs.mentorName}</strong></p>
                    ${gs.description ? `<p class="text-neutral-500 text-sm mb-2">${gs.description}</p>` : ''}
                    <p class="text-neutral-500 text-sm"><i class="fas fa-calendar mr-2"></i>${formatDate(gs.date)} at ${formatTime(gs.time)}</p>
                    <p class="text-neutral-400 text-xs mt-1"><i class="fas fa-users mr-1"></i>${gs.participantCount}/${gs.maxMentees} joined${isFull ? ' · Full' : ` · ${spotsLeft} spots left`}</p>
                  </div>
                  <div class="flex flex-col gap-2 min-w-max">
                    ${joined && !isPast ? `
                      <button onclick="joinGroupCall('${gs.id}')" class="bg-primary-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-primary-600 text-sm flex items-center">
                        <i class="fas fa-video mr-2"></i>Join Call
                      </button>` : ''}
                    ${!joined && !isPast ? (isFull ? `
                      <div class="bg-neutral-100 text-neutral-500 px-4 py-2 rounded-lg text-sm text-center">Session Full</div>` : `
                      <button onclick="joinGroupSession('${gs.id}', this)" class="bg-indigo-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-indigo-600 text-sm flex items-center justify-center">
                        <i class="fas fa-plus mr-2"></i>Join Session
                      </button>`) : ''}
                    ${joined && !isPast ? `<span class="bg-green-50 border border-green-200 text-green-700 px-3 py-1 rounded-lg text-xs text-center"><i class="fas fa-check-circle mr-1"></i>Enrolled</span>` : ''}
                    ${isPast && joined ? `<span class="bg-neutral-100 text-neutral-500 px-3 py-1 rounded-lg text-xs text-center">Completed</span>` : ''}
                  </div>
                </div>
              </div>`;
          }).join('');
        } catch (err) {
          container.innerHTML = '<p class="text-red-500 text-center py-4">Failed to load group sessions.</p>';
        }
      }

      async function joinGroupSession(groupSessionId, btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Joining...';
        try {
          const res  = await fetch('/join-group-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ groupSessionId, menteeId }),
          });
          const data = await res.json();
          if (data.success) {
            loadGroupSessions();
          } else {
            alert(data.message || 'Failed to join.');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-plus mr-2"></i>Join Session';
          }
        } catch (err) {
          alert('Error joining session.');
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-plus mr-2"></i>Join Session';
        }
      }

      function joinGroupCall(groupSessionId) {
        window.open(`/group-video-call/${groupSessionId}?userId=${menteeId}`, '_blank');
      }

      // ── Rating Modal ──────────────────────────────────────────────────────────
      function openRatingModal(sessionId, mentorId, mentorName) {
        currentReviewSession = { sessionId, mentorId };
        selectedRating = 0;
        document.getElementById('ratingModalSubtitle').textContent = `Rate your session with ${mentorName}`;
        document.getElementById('reviewComment').value = '';
        document.querySelectorAll('.star-btn').forEach(btn => {
          btn.classList.remove('text-yellow-400');
          btn.classList.add('text-neutral-300');
        });
        document.getElementById('ratingModal').classList.remove('hidden');
      }

      function closeRatingModal() {
        document.getElementById('ratingModal').classList.add('hidden');
        currentReviewSession = null;
        selectedRating = 0;
      }

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.star-btn').forEach(btn => {
          btn.addEventListener('mouseover', () => highlightStars(+btn.dataset.star));
          btn.addEventListener('mouseout',  () => highlightStars(selectedRating));
          btn.addEventListener('click',     () => { selectedRating = +btn.dataset.star; highlightStars(selectedRating); });
        });
        document.getElementById('ratingModal').addEventListener('click', e => {
          if (e.target === document.getElementById('ratingModal')) closeRatingModal();
        });
      });

      function highlightStars(count) {
        document.querySelectorAll('.star-btn').forEach(btn => {
          const star = +btn.dataset.star;
          btn.classList.toggle('text-yellow-400', star <= count);
          btn.classList.toggle('text-neutral-300', star > count);
        });
      }

      async function submitReview() {
        if (!selectedRating) return alert('Please select a star rating.');
        if (!currentReviewSession) return;

        const comment = document.getElementById('reviewComment').value.trim();
        try {
          const res  = await fetch('/submit-review', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({
              sessionId:  currentReviewSession.sessionId,
              mentorId:   currentReviewSession.mentorId,
              menteeId,
              menteeName: '', // filled server-side from menteeId if needed
              rating:     selectedRating,
              comment,
            }),
          });
          const data = await res.json();
          if (data.success) {
            closeRatingModal();
            loadBookings(); // Refresh to show "Reviewed" badge
          } else {
            alert(data.message || 'Failed to submit review.');
          }
        } catch (err) {
          alert('Error submitting review.');
        }
      }

      // ── Shared helpers ────────────────────────────────────────────────────────
      function joinVideoCall(sessionId) {
        window.open(`/video-call/${sessionId}?userId=${menteeId}`, '_blank');
      }

      function formatDate(dateString) {
        return new Date(dateString).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
      }

      function formatTime(timeString) {
        const [hours, minutes] = timeString.split(':');
        const hour = parseInt(hours);
        return `${hour % 12 || 12}:${minutes} ${hour >= 12 ? 'PM' : 'AM'}`;
      }

      function getTimeAgo(dateString) {
        const diffMs   = Date.now() - new Date(dateString);
        const diffMins = Math.floor(diffMs / 60000);
        const diffHrs  = Math.floor(diffMs / 3600000);
        const diffDays = Math.floor(diffMs / 86400000);
        if (diffMins < 60)  return diffMins <= 1 ? 'just now'  : `${diffMins}m ago`;
        if (diffHrs  < 24)  return diffHrs  === 1 ? '1 hour ago' : `${diffHrs}h ago`;
        if (diffDays < 7)   return diffDays === 1 ? '1 day ago'  : `${diffDays}d ago`;
        return new Date(dateString).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      function showError(message) {
        document.getElementById('menteeBookingsContainer').innerHTML = `
          <div class="text-center py-8 text-red-500">
            <i class="fas fa-exclamation-circle text-3xl mb-3"></i>
            <p>${message}</p>
            <button onclick="loadBookings()" class="mt-4 text-primary-500 hover:text-primary-600 font-medium"><i class="fas fa-refresh mr-2"></i>Try Again</button>
          </div>`;
      }

      async function logout() {
        const res = await fetch("/logout", { method: "POST" });
        if (res.ok) window.location.href = "/login";
      }

      function setupMobileMenu() {
        const btn  = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => menu.classList.toggle('hidden'));
        document.addEventListener('click', e => {
          if (!btn.contains(e.target) && !menu.contains(e.target)) menu.classList.add('hidden');
        });
      }
    </script>
  </body>
</html>